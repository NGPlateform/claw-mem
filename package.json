{
  "name": "chainofclaw-monorepo",
  "version": "1.0.7",
  "private": true,
  "description": "Monorepo root for @chainofclaw/node + @chainofclaw/soul + @chainofclaw/claw-mem (umbrella).",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
