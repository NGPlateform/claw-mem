{
  "name": "@openclaw/claw-mem",
  "version": "1.0.0",
  "description": "OpenClaw super-skill: persistent memory + COC node lifecycle + soul backup",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "bin": {
    "claw-mem": "./bin/claw-mem"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "service": {
      "id": "claw-mem",
      "label": "Claw-Mem: Memory + Node + Backup",
      "description": "Captures structured observations from agent sessions, runs COC nodes, and (PR 4) backs up agent souls"
    },
    "install": {
      "npmSpec": "@openclaw/claw-mem",
      "localPath": "extensions/claw-mem"
    }
  },
  "scripts": {
    "test": "node --experimental-strip-types --test test/*.test.ts test/backup-suite/*.test.ts",
    "test:watch": "node --experimental-strip-types --test --watch test/*.test.ts test/backup-suite/*.test.ts",
    "typecheck": "tsc --noEmit",
    "claw-mem": "node --experimental-strip-types src/cli/bin.ts"
  },
  "keywords": [
    "openclaw",
    "memory",
    "ai-agent",
    "semantic-memory",
    "coc",
    "blockchain"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^12.1.0",
    "ethers": "^6.16.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "index.ts",
    "src/",
    "bin/",
    "openclaw.plugin.json",
    "LICENSE"
  ]
}
