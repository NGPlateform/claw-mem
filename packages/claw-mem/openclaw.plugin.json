{
  "id": "claw-mem",
  "name": "Claw-Mem: Persistent Memory",
  "version": "1.1.7",
  "description": "OpenClaw skill: persistent semantic memory (observation capture, summaries, context injection). COC node lifecycle and soul backup moved to the @chainofclaw/node and @chainofclaw/soul sibling skills.",
  "main": "dist/index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "dataDir": { "type": "string", "default": "" },
      "tokenBudget": { "type": "number", "default": 8000 },
      "maxObservations": { "type": "number", "default": 50 },
      "maxSummaries": { "type": "number", "default": 10 },
      "dedupWindowMs": { "type": "number", "default": 30000 },
      "skipTools": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["TodoWrite", "AskUserQuestion", "Skill"]
      },
      "bootstrap": {
        "type": "object",
        "properties": {
          "mode": { "type": "string", "enum": ["none", "dev", "prod"], "default": "none" },
          "hardhatPort": { "type": "number", "default": 8545 },
          "autoFundEther": { "type": "string", "default": "0.1" },
          "operatorKeyPath": { "type": "string" },
          "cocRepoPath": { "type": "string" },
          "skipIfReady": { "type": "boolean", "default": true }
        }
      }
    }
  },
  "requirements": {
    "node": ">=22.0.0"
  }
}
