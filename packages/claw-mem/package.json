{
  "name": "@chainofclaw/claw-mem",
  "version": "1.1.16",
  "description": "OpenClaw super-skill: persistent memory + COC node lifecycle + soul backup",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "claw-mem": "./bin/claw-mem"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "service": {
      "id": "claw-mem",
      "label": "Claw-Mem: Memory + Node + Backup",
      "description": "Captures structured observations from agent sessions, runs COC nodes, and (PR 4) backs up agent souls"
    },
    "install": {
      "npmSpec": "@chainofclaw/claw-mem",
      "localPath": "extensions/claw-mem"
    }
  },
  "scripts": {
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "test:watch": "node --experimental-strip-types --test --watch test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "memory",
    "ai-agent",
    "semantic-memory",
    "coc",
    "blockchain"
  ],
  "license": "MIT",
  "homepage": "https://github.com/NGPlateform/claw-mem/tree/main/packages/claw-mem#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/NGPlateform/claw-mem.git",
    "directory": "packages/claw-mem"
  },
  "bugs": {
    "url": "https://github.com/NGPlateform/claw-mem/issues"
  },
  "dependencies": {
    "@chainofclaw/node": "1.1.15",
    "@chainofclaw/soul": "1.1.15",
    "@clack/prompts": "^0.10.0",
    "commander": "^12.1.0",
    "ethers": "^6.16.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.68.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/",
    "bin/",
    "src/",
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ]
}
