#!/bin/sh
# coc-node CLI shim — see bin/claw-mem for the matching pattern.
#
# Tries pre-compiled dist first (required for npm-installed usage because
# Node's --experimental-strip-types refuses to transform .ts files under
# node_modules), falls back to in-repo src/*.ts + --experimental-strip-types
# so the bin works before `npm run build`.

SCRIPT="$0"
while [ -h "$SCRIPT" ]; do
  TARGET=$(readlink "$SCRIPT")
  case "$TARGET" in
    /*) SCRIPT="$TARGET" ;;
    *)  SCRIPT="$(dirname "$SCRIPT")/$TARGET" ;;
  esac
done
DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"

if [ -f "$DIR/../dist/src/cli/bin.js" ]; then
  exec node --no-warnings "$DIR/../dist/src/cli/bin.js" "$@"
else
  exec node --experimental-strip-types --no-warnings "$DIR/../src/cli/bin.ts" "$@"
fi
