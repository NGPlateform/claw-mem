{
  "name": "@chainofclaw/node",
  "version": "1.1.5",
  "description": "OpenClaw skill: COC blockchain node lifecycle — install / start / stop / status for validator, fullnode, archive, gateway, dev nodes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./openclaw.plugin.json": "./openclaw.plugin.json"
  },
  "bin": {
    "coc-node": "./bin/coc-node"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "service": {
      "id": "coc-node",
      "label": "COC Node Lifecycle",
      "description": "Install, start, stop, and monitor COC blockchain nodes (validator / fullnode / archive / gateway / dev)."
    },
    "install": {
      "npmSpec": "@chainofclaw/node",
      "localPath": "extensions/coc-node"
    }
  },
  "scripts": {
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["coc", "chainofclaw", "blockchain", "node", "validator", "openclaw", "openclaw-skill"],
  "license": "MIT",
  "homepage": "https://github.com/NGPlateform/claw-mem/tree/main/packages/node#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/NGPlateform/claw-mem.git",
    "directory": "packages/node"
  },
  "bugs": {
    "url": "https://github.com/NGPlateform/claw-mem/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^12.1.0",
    "ethers": "^6.16.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/",
    "bin/",
    "src/",
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ]
}
