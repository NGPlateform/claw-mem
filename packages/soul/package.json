{
  "name": "@chainofclaw/soul",
  "version": "1.2.10",
  "description": "OpenClaw skill: COC soul layer — on-chain DID, guardian recovery, agent resurrection, soul backup, and carrier operations.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./openclaw.plugin.json": "./openclaw.plugin.json"
  },
  "bin": {
    "coc-soul": "./bin/coc-soul"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "service": {
      "id": "coc-soul",
      "label": "COC Soul Backup & Recovery",
      "description": "DID, guardian recovery, agent resurrection, soul backup, and carrier operations."
    },
    "install": {
      "npmSpec": "@chainofclaw/soul",
      "localPath": "extensions/coc-soul"
    }
  },
  "scripts": {
    "test": "node --experimental-strip-types --test test/*.test.ts test/backup-suite/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["coc", "chainofclaw", "did", "soul", "backup", "recovery", "ai-agent", "openclaw", "openclaw-skill"],
  "license": "MIT",
  "homepage": "https://github.com/NGPlateform/claw-mem/tree/main/packages/soul#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/NGPlateform/claw-mem.git",
    "directory": "packages/soul"
  },
  "bugs": {
    "url": "https://github.com/NGPlateform/claw-mem/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^12.1.0",
    "ethers": "^6.16.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/",
    "bin/",
    "src/",
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ]
}
