{
  "name": "@chainofclaw/soul",
  "version": "1.0.7",
  "description": "COC soul layer — on-chain DID, guardian recovery, agent resurrection, soul backup, and carrier operations.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "coc-soul": "./bin/coc-soul"
  },
  "scripts": {
    "test": "node --experimental-strip-types --test test/*.test.ts test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["coc", "chainofclaw", "did", "soul", "backup", "recovery", "ai-agent"],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^12.1.0",
    "ethers": "^6.16.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ]
}
